PORT=8787
NODE_ENV=development

# Production (Render, Railway, Fly.io, VPS): NODE_ENV=production + HTTPS reverse proxy.
# Secrets uniquement via variables d'environnement de la plateforme — ne jamais committer .env.

# Origines navigateur autorisées (séparées par des virgules).
# Vide = permissif (recommandé pour l'app Capacitor : pas d'Origin ou capacitor://localhost).
# Exemple web : CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# E-mail de bienvenue après connexion (Google ou e-mail) — API Resend (même clé que SMTP Supabase).
RESEND_API_KEY=re_xxxxxxxx
WELCOME_EMAIL_FROM=ModérScroll <noreply@moder-scroll.com>
